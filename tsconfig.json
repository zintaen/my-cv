{
    "extends": "./node_modules/@cyberskill/shared/public/tsconfig.base.json",
    "compilerOptions": {
        "ignoreDeprecations": "6.0",
        "incremental": true,
        "jsx": "react-jsx",
        "baseUrl": ".",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "paths": {
            "#public/*": [
                "public/*"
            ],
            "#shared/*": [
                "./src/shared/*"
            ]
        },
        "noEmit": true
    },
    "include": [
        "**/*.ts",
        "**/*.tsx"
    ]
}
